# Banco de Dados
DB_SERVER=127.0.0.1
DB_PORT=3306
DB_DATABASE=GestaoOficina
DB_USER=root
DB_PASSWORD=

# API (Kestrel servidor interno do .net)
ASPNETCORE_URLS=http://localhost:5233
# Deploy: ASPNETCORE_URLS=http://SEU_IP:5233

# CORS (origens do frontend separadas por vírgula)
CORS_ORIGINS=http://localhost:4200
# Deploy: CORS_ORIGINS=http://SEU_IP:4200,https://seu-dominio.com

# JWT
JWT_KEY=sua-chave-secreta-com-pelo-menos-64-caracteres-aqui
JWT_ISSUER=GestaoOficina
JWT_EXPIRATION_HOURS=8

# Serviço de email
SMTP__HOST=smtp.mailpit.local
SMTP__PORT=1025
SMTP__USER=usuario
SMTP__PASS=senha
SMTP__FROM=no-reply@gestaooficina.com
